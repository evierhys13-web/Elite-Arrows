rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.email in [
          'rhyshowe2023@outlook.com',
          'Rhyshowe2023@outlook.com',
          'dhineberry@yahoo.com',
          'Dhineberry@yahoo.com',
          'test@elitearrows.co.uk'
        ] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isTournamentAdmin == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCupAdmin == true
        ))
      );
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isFixtureParticipant(data) {
      return signedIn() && (
        data.get('player1Id', '') == request.auth.uid ||
        data.get('player2Id', '') == request.auth.uid ||
        data.get('player1', '') == request.auth.uid ||
        data.get('player2', '') == request.auth.uid
      );
    }

    function participantFixtureUpdateIsSafe() {
      // List fields that a participant is NOT allowed to change to prevent identity tampering.
      // They can change status, dates, scores, and set the _deleted flag.
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return !affected.hasAny([
        'id',
        'player1Id',
        'player2Id',
        'player1',
        'player2',
        'cupId',
        'matchId',
        'createdBy',
        'createdAt'
      ]);
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId) || isAdmin();
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['friends', 'sentFriendRequests', 'receivedFriendRequests']);
    }

    match /results/{resultId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /chatMessages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (isOwner(resource.data.senderId) || isAdmin());
      allow delete: if request.auth != null &&
        (isOwner(resource.data.senderId) || isAdmin());
    }

    match /fixtures/{fixtureId} {
      allow read: if signedIn();
      allow create: if signedIn() && (isAdmin() || isFixtureParticipant(request.resource.data));
      allow update: if signedIn() && (isAdmin() || (
        isFixtureParticipant(resource.data) &&
        participantFixtureUpdateIsSafe()
      ));
      allow delete: if signedIn() && (isAdmin() || (
        isFixtureParticipant(resource.data) &&
        resource.data.get('cupId', null) == null &&
        resource.data.get('status', '') in ['pending', 'countered']
      ));
    }

    match /cups/{cupId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /tournaments/{tournamentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /tournament_records/{recordId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /adminData/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /supportRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
    }

    match /seasons/{seasonId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /fcmTokens/{tokenId} {
      allow read, write: if request.auth != null;
    }

    match /bets/{betId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /tournamentSignups/{signupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }
  }
}
