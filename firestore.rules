rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isTournamentAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCupAdmin == true ||
        request.auth.token.email in [
          'rhyshowe2023@outlook.com',
          'dhineberry@yahoo.com',
          'test@elitearrows.co.uk'
        ]
      );
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isFixtureParticipant(data) {
      return signedIn() && (
        data.player1Id == request.auth.uid ||
        data.player2Id == request.auth.uid ||
        data.player1 == request.auth.uid ||
        data.player2 == request.auth.uid
      );
    }

    function participantFixtureUpdateIsSafe() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'proposalStatus',
        'proposedDate',
        'proposedTime',
        'proposedBy',
        'counterDate',
        'counterTime',
        'counterBy',
        'counteredAt',
        'fixtureDate',
        'fixtureTime',
        'date',
        'time',
        'scheduledBy',
        'resultId',
        'submittedResultId',
        'score1',
        'score2',
        'updatedAt'
      ]);
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId) || isAdmin();
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['friends', 'sentFriendRequests', 'receivedFriendRequests']);
    }

    match /results/{resultId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /chatMessages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (isOwner(resource.data.senderId) || isAdmin());
      allow delete: if request.auth != null &&
        (isOwner(resource.data.senderId) || isAdmin());
    }

    match /fixtures/{fixtureId} {
      allow read: if request.auth != null;
      allow create: if isAdmin() || isFixtureParticipant(request.resource.data);
      allow update: if isAdmin() || (
        isFixtureParticipant(resource.data) &&
        isFixtureParticipant(request.resource.data) &&
        participantFixtureUpdateIsSafe()
      );
      allow delete: if isAdmin() || (
        isFixtureParticipant(resource.data) &&
        resource.data.cupId == null &&
        resource.data.status in ['pending', 'countered']
      );
    }

    match /cups/{cupId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /tournaments/{tournamentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /adminData/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /supportRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
    }

    match /seasons/{seasonId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /fcmTokens/{tokenId} {
      allow read, write: if request.auth != null;
    }

    match /bets/{betId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /tournamentSignups/{signupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }
  }
}
